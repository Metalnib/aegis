{
  "name": "@aegis/sdk",
  "version": "0.1.0",
  "description": "Public types and SPIs for Aegis adapters",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "node --import tsx --test 'test/**/*.test.ts'"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "*"
  }
}
